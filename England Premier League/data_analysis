# 4. Final Output & Model Comparison
#----------------=================================#
# Define Null Model (Linear Transitivty Only) for baseline
LB = L_Mat %*% BK
null_lm = lm(bY ~ 0 + LB)

get_model_metrics <- function(selected_cols, model_name) {
  if(length(selected_cols) == 0) return(c(model_name, 0, AIC(null_lm), BIC(null_lm)))
  
  mod_lm <- lm(bY ~ 0 + LB + (L_Mat %*% CK)[, selected_cols, drop=FALSE])
  return(c(model_name, length(selected_cols), round(AIC(mod_lm), 2), round(BIC(mod_lm), 2)))
}

res_table <- rbind(
  c("Baseline (Linear Transitivity)", 0, round(AIC(null_lm), 2), round(BIC(null_lm), 2)),
  get_model_metrics(lasso_select, "Standard LASSO"),
  get_model_metrics(final_cols_h, "Hybrid (LASSO + FTBS)"),
  get_model_metrics(final_cols_ftbs, "Pure FTBS (FDR + Pruning)")
)

colnames(res_table) <- c("Method", "Selected Triads", "AIC", "BIC")
rownames(res_table) <- NULL

